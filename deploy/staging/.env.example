# Copy this file to .env on the staging host.
# Do not commit the copied .env file or real staging secrets.
# Ansible initializes server-generated secrets when values are empty or still
# use the replace-with-staging-* placeholders.

# -------------------------------------------------------------------
# Deployment identity
# -------------------------------------------------------------------
PEGELHUB_ENVIRONMENT=staging
PEGELHUB_DEPLOY_MARKER=pegelhub-staging
COMPOSE_PROJECT_NAME=pegelhub-staging
# COMPOSE_PROFILES=frontend

# -------------------------------------------------------------------
# Image versions
# Usually changed by deployment automation.
# -------------------------------------------------------------------
# Examples: v0.1.0, sha-42bd19b
PEGELHUB_IMAGE_TAG=sha-replace-me
PEGELHUB_FRONTEND_IMAGE=ghcr.io/viadonau/pegelhub-frontend:sha-replace-me

# -------------------------------------------------------------------
# Public hostnames
# Set once after DNS is known.
# -------------------------------------------------------------------
PEGELHUB_FRONTEND_HOSTNAME=pegelhub-staging.example.com
PEGELHUB_API_HOSTNAME=api-pegelhub-staging.example.com
PEGELHUB_KEYCLOAK_HOSTNAME=auth-pegelhub-staging.example.com

# -------------------------------------------------------------------
# Metadata database
# META_PASSWORD is generated once on the staging host.
# -------------------------------------------------------------------
META_DB=pegelhub
META_PASSWORD=replace-with-staging-meta-password

# -------------------------------------------------------------------
# InfluxDB
# Password/token values are generated once on the staging host.
# -------------------------------------------------------------------
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=replace-with-staging-influx-admin-password
INFLUX_ORG=pegelhub
INFLUX_INTERNAL_BUCKET=pegelhub-internal
INFLUX_DATA_BUCKET=pegelhub-data
INFLUX_TELEMETRY_BUCKET=pegelhub-telemetry
INFLUX_TOKEN=replace-with-staging-influx-token

# -------------------------------------------------------------------
# Keycloak
# Password values are generated once on the staging host.
# -------------------------------------------------------------------
KEYCLOAK_DB=keycloak
KEYCLOAK_DB_PASSWORD=replace-with-staging-keycloak-db-password
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-staging-keycloak-admin-password

# -------------------------------------------------------------------
# FTP connector runtime config
# Real FTP credentials live in this host-mounted directory, not in .env.
# -------------------------------------------------------------------
# The directory must contain connector.properties and pegelhub.yaml.
FTP_CONFIG_DIR=./ftp-config

# -------------------------------------------------------------------
# Runtime tuning
# -------------------------------------------------------------------
CORE_JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75
FTP_JAVA_TOOL_OPTIONS=-DLOG_LEVEL=INFO
