# Copy this file to .env.release and set real values before running
# docker-compose.release.yaml. Do not commit filled-in secrets.

PEGELHUB_CORE_IMAGE=ghcr.io/example-owner/pegelhub-core:v0.1.0

META_DB=pegelhub
META_PASSWORD=change-me

INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=change-me
INFLUX_ORG=pegelhub
INFLUX_INTERNAL_BUCKET=pegelhub-internal
INFLUX_DATA_BUCKET=pegelhub-data
INFLUX_TELEMETRY_BUCKET=pegelhub-telemetry
INFLUX_TOKEN=change-me

KEYCLOAK_DB=keycloak
KEYCLOAK_DB_PASSWORD=change-me
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_HOSTNAME_URL=http://pegelhub-keycloak.test:8082
KEYCLOAK_ISSUER_URI=http://pegelhub-keycloak.test:8082/realms/pegelhub
PEGELHUB_API_AUDIENCE=pegelhub-core-api
