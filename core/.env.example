# Copy this file to .env for local Docker Compose runs.
# Do not commit real local or production credentials.

META_DB=pegelhub
META_PASSWORD=postgres

# InfluxDB first-start admin credentials for the local container.
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=admin1234

# Shared InfluxDB runtime config. The same token is passed to InfluxDB
# during first-start setup and to core-app for bucket access.
INFLUX_ORG=pegelhub
INFLUX_INTERNAL_BUCKET=pegelhub-internal
INFLUX_DATA_BUCKET=pegelhub-data
INFLUX_TELEMETRY_BUCKET=pegelhub-telemetry
INFLUX_TOKEN=local-dev-influx-token-change-me-000000000000000000000000000000
